{
  "name": "epicerie-caisse",
  "version": "1.0.0",
  "description": "Logiciel de caisse pour épicerie de quartier",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "jest",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.epicerie.caisse",
    "productName": "Épicerie Caisse",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "services/**/*", "ipc/**/*", "renderer/**/*", "node_modules/**/*"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" },
    "nsis": { "oneClick": true, "createDesktopShortcut": true, "createStartMenuShortcut": true }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
